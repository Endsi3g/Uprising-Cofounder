# .env.example — Uprising Cofounder
# Copiez ce fichier vers .env et remplissez les valeurs.
# Ne commitez JAMAIS le fichier .env dans git.

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
JWT_SECRET=votre_secret_jwt_très_long_et_aléatoire

# ── Database ─────────────────────────────────────────────────────────────────
# Option 1: Local PostgreSQL (dev)
DATABASE_URL=postgresql://uprising:password@localhost:5433/uprising_crm

# Option 2: Supabase (production)
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.XXXX.supabase.co:5432/postgres

# ─ Supabase (SDK optionnel pour Row Level Security) ──────────────────────────
SUPABASE_URL=https://XXXX.supabase.co
SUPABASE_ANON_KEY=

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Valeurs: gemini | groq | openrouter | local
LLM_PROVIDER=gemini

# Google Gemini (recommandé — marché canadien)
GEMINI_API_KEY=

# Groq (ultra-rapide, tier gratuit généreux)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter (accès à 100+ modèles)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=mistralai/mixtral-8x7b-instruct

# Local Ollama (Docker — aucun coût API)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# ── Upstash Redis — File d'attente asynchrone (BullMQ) ───────────────────────
# Créez un compte gratuit sur upstash.com → Redis → "TLS" requis
UPSTASH_REDIS_URL=rediss://default:TOKEN@xxx.upstash.io:6380

# ── PostHog — Analytics produit ──────────────────────────────────────────────
# Côté backend (Node.js)
POSTHOG_API_KEY=phc_XXXX
POSTHOG_HOST=https://app.posthog.com

# Côté frontend (Vite) — préfixe VITE_ obligatoire
VITE_POSTHOG_KEY=phc_XXXX
VITE_POSTHOG_HOST=https://app.posthog.com

# ── SMTP — Emails transactionnels ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre@gmail.com
SMTP_PASS=votre_app_password_gmail
SMTP_FROM="Uprising Studio" <noreply@uprisingstudio.ca>

# ── Sentry — Error Tracking ───────────────────────────────────────────────────
VITE_SENTRY_DSN=

# ── Frontend (production uniquement) ─────────────────────────────────────────
# URL du backend Render (utilisée par Vercel pour le proxy /api)
VITE_API_URL=https://uprising-backend.onrender.com

# ── Bland AI — Appels téléphoniques IA ───────────────────────────────────────
BLAND_API_KEY=

# ── ElevenLabs — Synthèse vocale ─────────────────────────────────────────────
ELEVENLABS_API_KEY=

# ── Twilio — SMS & Voix ───────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ── Twenty CRM ───────────────────────────────────────────────────────────────
TWENTY_API_KEY=
TWENTY_API_URL=https://api.twenty.com

# ── AWS S3 (stockage fichiers optionnel) ─────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ca-central-1
AWS_S3_BUCKET=
